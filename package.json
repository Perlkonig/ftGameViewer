{
  "name": "ftgameviewer",
  "private": true,
  "version": "0.2.0-beta.1",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "npm run clean && npm run schemas && npm run docs && node bin/exportPresets.mjs",
    "postbuild": "shx cp -r src/schemas dist && rimraf -g dist/schemas/*.d.ts && node bin/exportCounters.mjs && node bin/exportPresets.mjs && shx cp -r public/presets dist/presets && node bin/buildCounterSheet.mjs dist/docs && node bin/buildDocs.mjs dist/docs",
    "predev": "node bin/exportPresets.mjs && npm run docs",
    "dev": "cross-env NODE_ENV=development vite",
    "build": "cross-env NODE_ENV=production vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json && npm run lint:markup",
    "lint:markup": "node bin/checkSvelteMarkup.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "schemas": "json2ts -i src/schemas/position.json -o src/schemas/position.d.ts --cwd src/schemas && json2ts -i src/schemas/commands.json -o src/schemas/commands.d.ts --cwd src/schemas && json2ts -i src/schemas/game.json -o src/schemas/game.d.ts --cwd src/schemas",
    "presets": "node bin/exportPresets.mjs",
    "docs": "node bin/buildCounterSheet.mjs && node bin/buildDocs.mjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^22.15.0",
    "@types/rfdc": "^1.2.0",
    "cross-env": "^7.0.3",
    "json-schema-to-typescript": "^15.0.4",
    "marked": "^18.0.6",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "shx": "^0.4.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tslib": "^2.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vite": "^8.1.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@zerodevx/svelte-toast": "^0.9.6",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "crypto-js": "^4.2.0",
    "fast-xml-parser": "^5.2.5",
    "ftlibship": "github:perlkonig/ftlibship",
    "json-stringify-deterministic": "^1.0.12",
    "nanoid": "^5.1.6",
    "rfdc": "^1.4.1"
  }
}
